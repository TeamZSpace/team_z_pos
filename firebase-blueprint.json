{
  "entities": {
    "Supplier": {
      "title": "Supplier",
      "description": "A supplier of products",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" }
      },
      "required": ["id", "name", "phone"]
    },
    "Category": {
      "title": "Category",
      "description": "A product category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "parentId": { "type": "string" }
      },
      "required": ["id", "name"]
    },
    "Product": {
      "title": "Product",
      "description": "An inventory item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "subCategory": { "type": "string" },
        "costPrice": { "type": "number" },
        "shippingPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "stock": { "type": "number" },
        "madeIn": { "type": "string" },
        "supplierId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "category", "costPrice", "sellingPrice", "stock", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer who has made a purchase",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "facebookName": { "type": "string" },
        "orderName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["id", "phone"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A sales transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderNumber": { "type": "string" },
        "items": { "type": "array" },
        "customer": { "type": "object" },
        "totalRevenue": { "type": "number" },
        "totalCost": { "type": "number" },
        "date": { "type": "string" },
        "saleDate": { "type": "string" },
        "deliveryDate": { "type": "string" },
        "paymentVoucherUrl": { "type": "string" }
      },
      "required": ["id", "orderNumber", "items", "customer", "totalRevenue", "totalCost", "date"]
    },
    "Expense": {
      "title": "Expense",
      "description": "A business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string" },
        "voucherUrl": { "type": "string" }
      },
      "required": ["id", "type", "amount", "date"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "An accounting journal entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "debit_account_id": { "type": "string" },
        "credit_account_id": { "type": "string" },
        "amount": { "type": "number" },
        "reference_type": { "type": "string" },
        "description": { "type": "string" },
        "reference_id": { "type": "string" },
        "contact_id": { "type": "string" }
      },
      "required": ["id", "date", "debit_account_id", "credit_account_id", "amount", "reference_type", "description"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "A purchase of inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "costPrice": { "type": "number" },
        "shippingPrice": { "type": "number" },
        "totalAmount": { "type": "number" },
        "date": { "type": "string" },
        "supplierId": { "type": "string" }
      },
      "required": ["id", "productId", "productName", "quantity", "costPrice", "totalAmount", "date"]
    },
    "BusinessProfile": {
      "title": "Business Profile",
      "description": "Information about the business",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "googleSheetUrl": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/users/{businessId}/suppliers/{supplierId}": { "schema": "Supplier", "description": "Suppliers for a business" },
    "/users/{businessId}/categories/{categoryId}": { "schema": "Category", "description": "Categories for a business" },
    "/users/{businessId}/products/{productId}": { "schema": "Product", "description": "Products for a business" },
    "/users/{businessId}/customers/{customerId}": { "schema": "Customer", "description": "Customers for a business" },
    "/users/{businessId}/sales/{saleId}": { "schema": "Sale", "description": "Sales for a business" },
    "/users/{businessId}/expenses/{expenseId}": { "schema": "Expense", "description": "Expenses for a business" },
    "/users/{businessId}/journalEntries/{entryId}": { "schema": "JournalEntry", "description": "Journal entries for a business" },
    "/users/{businessId}/purchases/{purchaseId}": { "schema": "Purchase", "description": "Purchases for a business" },
    "/users/{businessId}/profile/data": { "schema": "BusinessProfile", "description": "Profile data for a business" }
  }
}
