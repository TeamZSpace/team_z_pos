rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAuthorized() {
      return isAuthenticated() && 
        (request.auth.token.email == "diginestt2026@gmail.com" || 
         request.auth.token.email == "myatbinance@gmail.com") &&
        request.auth.token.email_verified == true;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProduct(data) {
      return hasRequiredFields(['id', 'name', 'category', 'costPrice', 'sellingPrice', 'stock', 'createdAt']) &&
             data.id is string && data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.costPrice is number && data.sellingPrice is number && data.stock is number;
    }

    function isValidSale(data) {
      return hasRequiredFields(['id', 'orderNumber', 'items', 'customer', 'totalRevenue', 'totalCost', 'date']) &&
             data.id is string && data.orderNumber is string && data.items is list && data.customer is map;
    }

    function isValidExpense(data) {
      return hasRequiredFields(['id', 'type', 'amount', 'date']) &&
             data.id is string && data.amount is number && data.date is string;
    }

    function isValidCategory(data) {
      return hasRequiredFields(['id', 'name']) &&
             data.id is string && data.name is string;
    }

    function isValidCustomer(data) {
      return hasRequiredFields(['id', 'phone']) &&
             data.id is string && data.phone is string;
    }

    function isValidSupplier(data) {
      return hasRequiredFields(['id', 'name', 'phone']) &&
             data.id is string && data.name is string && data.phone is string;
    }

    function isValidJournalEntry(data) {
      return hasRequiredFields(['id', 'date', 'debit_account_id', 'credit_account_id', 'amount', 'reference_type', 'description']) &&
             data.id is string && data.amount is number;
    }

    function isValidPurchase(data) {
      return hasRequiredFields(['id', 'productId', 'productName', 'quantity', 'costPrice', 'totalAmount', 'date']) &&
             data.id is string && data.quantity is number && data.totalAmount is number;
    }

    function isValidProfile(data) {
      return hasRequiredFields(['name']) && data.name is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{businessId}/products/{productId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidProduct(request.resource.data);
      allow delete: if isAuthorized();
    }

    match /users/{businessId}/sales/{saleId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidSale(request.resource.data);
      allow delete: if isAuthorized();
    }

    match /users/{businessId}/expenses/{expenseId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidExpense(request.resource.data);
      allow delete: if isAuthorized();
    }

    match /users/{businessId}/categories/{categoryId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidCategory(request.resource.data);
      allow delete: if isAuthorized();
    }

    match /users/{businessId}/customers/{customerId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidCustomer(request.resource.data);
      allow delete: if isAuthorized();
    }

    match /users/{businessId}/suppliers/{supplierId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidSupplier(request.resource.data);
      allow delete: if isAuthorized();
    }

    match /users/{businessId}/journalEntries/{entryId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidJournalEntry(request.resource.data);
      allow delete: if isAuthorized();
    }

    match /users/{businessId}/purchases/{purchaseId} {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidPurchase(request.resource.data);
      allow delete: if isAuthorized();
    }

    match /users/{businessId}/profile/data {
      allow read: if isAuthorized();
      allow create, update: if isAuthorized() && isValidProfile(request.resource.data);
      allow delete: if isAuthorized();
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
